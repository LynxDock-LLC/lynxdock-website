# Copy to .env.local (or set in Cloudflare Pages env vars) to enable optional
# features. Both are inert when left empty.

# Early-access form endpoint. Any service that accepts a JSON POST works
# (e.g. Formspree: https://formspree.io/f/XXXXXXXX). When empty, the form
# falls back to a prefilled mailto link so no submission is ever lost.
NEXT_PUBLIC_FORM_ENDPOINT=

# Cloudflare Web Analytics token (privacy-first, cookieless). Get it from the
# Cloudflare dashboard > Web Analytics > add a site. When empty, no analytics
# script loads at all.
NEXT_PUBLIC_CF_BEACON_TOKEN=
